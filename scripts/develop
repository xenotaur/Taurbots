#!/usr/bin/env bash
set -euo pipefail

python_bin="${PYTHON:-python3}"
constraints=()

if [[ -f constraints.txt ]]; then
  constraints=(-c constraints.txt)
elif [[ -f requirements/constraints.txt ]]; then
  constraints=(-c requirements/constraints.txt)
fi

"${python_bin}" -m pip install --upgrade pip
"${python_bin}" -m pip install "${constraints[@]}" -e '.[dev]'
